# === Environment ===
.env
.env.local

# === Unity (github/gitignore Unity.gitignore ベース) ===
# https://github.com/github/gitignore/blob/main/Unity.gitignore
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Visual Studio cache directory
.vs/
.idea/
.vscode/

# Gradle cache directory (Android ビルド)
.gradle/

# Autogenerated VS/MD/JB solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds (Android / iOS / 配布)
*.apk
*.aab
*.ipa
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Addressables-generated link.xml (IL2CPP strip preservation; regenerated at build time)
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml.meta

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# === OS ===
.DS_Store
Thumbs.db
desktop.ini
# Windows ADS (Alternate Data Stream) メタデータ
*:Zone.Identifier

# === Editor ===
*.swp
*~
